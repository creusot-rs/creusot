    -> Seq.(++) (Seq.empty: Seq.seq t_Item) (Seq.empty: Seq.seq t_Item) = (Seq.empty: Seq.seq t_Item)
    && ([@stop_split] [@expl:produces_inner_trans ensures] produces_inner_A x (Seq.(++) visited_a_xy visited_a_yz) (Seq.(++) visited_b_xy visited_b_yz) z)
