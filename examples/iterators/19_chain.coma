    forall a'0: t_B, ab: Seq.seq t_Item, b'0: t_B, bc: Seq.seq t_Item, c: t_B. produces_B a'0 ab b'0
      -> produces_B b'0 bc c -> produces_B a'0 (Seq.(++) ab bc) c
  
