  predicate produces_back_RangeInclusive (self: t_RangeInclusive) (visited: Seq.seq Int32.t) (o: t_RangeInclusive) =
    Seq.length visited = len_log self - len_log o
    /\ (is_empty_log self -> is_empty_log o)
    /\ (is_empty_log o \/ self.start = o.start)
    /\ (forall i: int. 0 <= i /\ i < Seq.length visited
