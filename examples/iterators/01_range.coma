      | s1 = any [ br0 -> {is_iterating = false} (! bb5) | br1 -> {is_iterating} (! bb4) ] ]
    | bb4 = s0
      [ s0 = [ &r <- self.current.end' ] s1
      | s1 = Int32.sub {self.current.end'} {(1: Int32.t)}
          (fun (_x: Int32.t) -> [ &self <- { self with current = { self.current with end' = _x } } ] s2)
      | s2 = -{resolve_refmut_RangeInclusive self}- s3
      | s3 = [ &_11 <- r ] s4
      | s4 = bb6 ]
    | bb5 = s0
      [ s0 = [ &self <- { self with current = { self.current with exhausted = true } } ] s1
      | s1 = -{resolve_refmut_RangeInclusive self}- s2
      | s2 = [ &_11 <- self.current.end' ] s3
      | s3 = bb6 ]
    | bb6 = s0 [ s0 = [ &_ret <- Some _11 ] s1 | s1 = return {_ret} ] ]
    [ & _ret: t_Option_i32 = Any.any_l ()
    | & self: MutBorrow.t t_RangeInclusive = self
    | & _5: bool = Any.any_l ()
    | & is_iterating: bool = Any.any_l ()
    | & _11: Int32.t = Any.any_l ()
    | & r: Int32.t = Any.any_l () ])
    [ return (result: t_Option_i32) -> {[@stop_split] [@expl:next_back ensures] match result with
        | None -> completed_back_RangeInclusive self
        | Some v -> produces_back_RangeInclusive self.current (Seq.singleton v) self.final
        end}
