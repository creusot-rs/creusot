    /\ (let s = deep_model_isize self'0.end' - deep_model_isize self'0.start in s >= 0 /\ s <= UInt64.t'int const_MAX
      -> UInt64.t'int result.f0 = s /\ result.f1 = Some (result.f0))
    /\ (deep_model_isize self'0.end' - deep_model_isize self'0.start > UInt64.t'int const_MAX
    -> result = { f0 = const_MAX; f1 = None })
  
