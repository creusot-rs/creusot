  use creusot.int.UInt64BW
  use seq.Seq
  use creusot.prelude.MutBorrow
  use int.Int
  
  type t_RangeInclusive = { start: Int32BW.t; end': Int32BW.t; exhausted: bool }
  
  type t_Ordering = Less | Equal | Greater
  
  function cmp_log_i32 (self: Int32BW.t) (o: Int32BW.t) : t_Ordering = if Int32BW.lt self o then
      Less
    else
      if self = o then Equal else Greater
  
  
  function eq_cmp_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom eq_cmp_i32_spec: forall x: Int32BW.t, y: Int32BW.t. (x = y) = (cmp_log_i32 x y = Equal)
  
  function antisym2_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom antisym2_i32_spec: forall x: Int32BW.t, y: Int32BW.t. cmp_log_i32 x y = Greater -> cmp_log_i32 y x = Less
  
  function antisym1_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom antisym1_i32_spec: forall x: Int32BW.t, y: Int32BW.t. cmp_log_i32 x y = Less -> cmp_log_i32 y x = Greater
  
  function trans_i32 (x: Int32BW.t) (y: Int32BW.t) (z: Int32BW.t) (o: t_Ordering) : ()
  
  axiom trans_i32_spec: forall x: Int32BW.t, y: Int32BW.t, z: Int32BW.t, o: t_Ordering. cmp_log_i32 x y = o
      -> cmp_log_i32 y z = o -> cmp_log_i32 x z = o
  
  function refl_i32 (x: Int32BW.t) : ()
  
  axiom refl_i32_spec: forall x: Int32BW.t. cmp_log_i32 x x = Equal
  
  function cmp_gt_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom cmp_gt_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.gt x y = (cmp_log_i32 x y = Greater)
  
  function cmp_ge_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom cmp_ge_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.ge x y = (cmp_log_i32 x y <> Less)
  
  function cmp_lt_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom cmp_lt_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.lt x y = (cmp_log_i32 x y = Less)
  
  function cmp_le_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom cmp_le_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.le x y = (cmp_log_i32 x y <> Greater)
  
  predicate is_empty_log (self: t_RangeInclusive) = Int32BW.gt self.start self.end' \/ self.exhausted
  
  function len_log (self: t_RangeInclusive) : int = if is_empty_log self then
      0
    else
      Int32BW.to_int self.end' - Int32BW.to_int self.start + 1
  
  
  constant const_MAX: UInt64BW.t = (18446744073709551615: UInt64BW.t)
  
  type t_Option_usize = None | Some UInt64BW.t
  
  type tup2_usize_Option_usize = { f0: UInt64BW.t; f1: t_Option_usize }
  
  predicate produces_RangeInclusive (self: t_RangeInclusive) (visited: Seq.seq Int32BW.t) (o: t_RangeInclusive) =
    Seq.length visited = len_log self - len_log o
    /\ (is_empty_log self -> is_empty_log o)
    /\ (is_empty_log o \/ self.end' = o.end')
    /\ (forall i: int. 0 <= i /\ i < Seq.length visited
      -> Int32BW.to_int (Seq.get visited i) = Int32BW.to_int self.start + i)
  
  predicate completed_RangeInclusive (self: MutBorrow.t t_RangeInclusive) =
    is_empty_log self.current /\ is_empty_log self.final
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  goal refines: forall self: t_RangeInclusive. forall result: tup2_usize_Option_usize. (len_log self
              <= UInt64BW.t'int const_MAX -> UInt64BW.t'int result.f0 = len_log self /\ result.f1 = Some (result.f0))
          /\ (len_log self > UInt64BW.t'int const_MAX -> result = { f0 = const_MAX; f1 = None })
        -> (forall s: Seq.seq Int32BW.t, i: MutBorrow.t t_RangeInclusive. produces_RangeInclusive self s i.current
              /\ completed_RangeInclusive i -> UInt64BW.t'int result.f0 <= Seq.length s)
        /\ match result.f1 with
          | Some r -> forall s: Seq.seq Int32BW.t, i: t_RangeInclusive. produces_RangeInclusive self s i
            -> Seq.length s <= UInt64BW.t'int r
          | None -> true
          end
end
