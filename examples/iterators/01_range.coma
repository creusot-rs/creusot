  meta "select_lsinst" "all"
  
  let next_back_RangeInclusive (self: MutBorrow.t t_RangeInclusive) (return (x: t_Option_i32)) = (! bb0
    [ bb0 = s0
      [ s0 = is_empty {self.current} (fun (_x: bool) -> [ &_5 <- _x ] s1)
      | s1 = any [ br0 -> {_5 = false} (! bb3) | br1 -> {_5} (! bb2) ] ]
    | bb2 = s0 [ s0 = -{resolve_refmut_RangeInclusive self}- s1 | s1 = [ &_ret <- None ] s2 | s2 = return {_ret} ]
    | bb3 = s0
