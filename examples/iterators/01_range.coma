      | s3 = return {_ret} ] ]
    [ & _ret: t_Option_isize = Any.any_l () | & self: MutBorrow.t t_Range = self | & _4: bool = Any.any_l () ])
    [ return (result: t_Option_isize) -> {[@stop_split] [@expl:next_back ensures] match result with
        | None -> completed_back_Range self
        | Some v -> produces_back_Range self.current (Seq.singleton v) self.final
        end}
      (! return {result}) ]
end
