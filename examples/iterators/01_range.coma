      | s1 = [ &steps <- _12 ] s2
      | s2 = [ &_16 <- Some steps ] s3
      | s3 = [ &_ret <- { f0 = steps; f1 = _16 } ] s4
      | s4 = return {_ret} ]
    | bb3 = s0
      [ s0 = [ &_18 <- Some (0: UInt64BW.t) ] s1
      | s1 = [ &_ret <- { f0 = (0: UInt64BW.t); f1 = _18 } ] s2
      | s2 = return {_ret} ] ]
    [ & _ret: tup2_usize_Option_usize = Any.any_l ()
    | & self: t_Range = self
    | & _8: bool = Any.any_l ()
    | & steps: UInt64BW.t = Any.any_l ()
    | & _12: Int64BW.t = Any.any_l ()
    | & _16: t_Option_usize = Any.any_l ()
    | & _18: t_Option_usize = Any.any_l () ])
    [ return (result: tup2_usize_Option_usize) ->
