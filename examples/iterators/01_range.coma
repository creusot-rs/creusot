  function produces_refl_Range (self: t_Range) : () = ()
  
  axiom produces_refl_Range_spec: forall self: t_Range. produces_Range self (Seq.empty: Seq.seq Int64.t) self
  
  let size_hint_Range (self: t_Range) (return (x: tup2_usize_Option_usize)) = any
    [ return (result: tup2_usize_Option_usize) ->
    {[@stop_split] [@expl:size_hint_Range ensures] ([@stop_split] [@expl:size_hint ensures #0] deep_model_isize self.start
          >= deep_model_isize self.end' -> result = { f0 = (0: UInt64.t); f1 = Some (0: UInt64.t) })
      /\ ([@stop_split] [@expl:size_hint ensures #1] let s = deep_model_isize self.end'
