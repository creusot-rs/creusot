        {[@expl:loop invariant #1] Int64.to_int i = Seq.length produced /\ Int64.le i n}
        (! s0)
        [ s0 = MutBorrow.borrow_mut <t_Range> {it}
            (fun (_bor: MutBorrow.t t_Range) -> [ &_27 <- _bor ] [ &it <- _bor.final ] s1)
        | s1 = next_Range {_27} (fun (_x: t_Option_isize) -> [ &_26 <- _x ] s2)
        | s2 = any [ br0 -> {_26 = None} (! bb9) | br1 (x0: Int64.t) -> {_26 = Some x0} (! bb10) ] ]
        [ bb10 = s0
          [ s0 = elim_Some {_26} (fun (r0: Int64.t) -> [ &x <- r0 ] s1)
          | s1 = [ &produced <- Seq.(++) produced (Seq.singleton x) ] s2
          | s2 = Int64.add {i} {(1: Int64.t)} (fun (_x: Int64.t) -> [ &i <- _x ] s3)
          | s3 = bb4 ] ] ]
    | bb9 = s0 [ s0 = [ &_ret <- i ] s1 | s1 = return {_ret} ] ]
    [ & _ret: Int64.t = Any.any_l ()
    | & n: Int64.t = n
    | & i: Int64.t = Any.any_l ()
    | & it: t_Range = Any.any_l ()
    | & _8: t_Range = Any.any_l ()
    | & iter_old: t_Range = Any.any_l ()
    | & produced: Seq.seq Int64.t = Any.any_l ()
    | & _26: t_Option_isize = Any.any_l ()
    | & _27: MutBorrow.t t_Range = Any.any_l ()
    | & x: Int64.t = Any.any_l () ])
    [ return (result: Int64.t) -> {[@stop_split] [@expl:sum_range ensures] result = n} (! return {result}) ]
end
