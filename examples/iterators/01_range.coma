        -> UInt64.t'int result.f0 = s /\ result.f1 = Some (result.f0))
      /\ ([@stop_split] [@expl:size_hint ensures #2] deep_model_isize self.end' - deep_model_isize self.start
        > UInt64.t'int const_MAX -> result = { f0 = const_MAX; f1 = None })}
      (! return {result}) ]
  
  predicate produces_back_Range (self: t_Range) (visited: Seq.seq Int64.t) (o: t_Range) =
    self.start = o.start
    /\ Int64.ge self.end' o.end'
    /\ (Seq.length visited > 0 -> Int64.ge o.end' o.start)
    /\ Seq.length visited = Int64.to_int self.end' - Int64.to_int o.end'
    /\ (forall i: int. 0 <= i /\ i < Seq.length visited
      -> Int64.to_int (Seq.get visited i) = Int64.to_int self.end' - i - 1)
  
  predicate resolve_refmut_Range [@inline:trivial] (_1: MutBorrow.t t_Range) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_Range
  
  predicate completed_Range (self: MutBorrow.t t_Range) =
    resolve_refmut_Range self /\ Int64.ge self.current.start self.current.end'
  
  predicate completed_back_Range (self: MutBorrow.t t_Range) = completed_Range self
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  goal refines: forall self: t_Range, r: tup2_usize_Option_usize. postcondition_size_hint () self r
      -> postcondition_size_hint () self r
      /\ (forall result: (). (forall s: Seq.seq Int64.t, i: MutBorrow.t t_Range. produces_back_Range self s i.current
                /\ completed_back_Range i -> UInt64.t'int r.f0 <= Seq.length s)
          /\ match r.f1 with
            | Some r'0 -> forall s: Seq.seq Int64.t, i: t_Range. produces_back_Range self s i
              -> Seq.length s <= UInt64.t'int r'0
            | None -> true
            end
        -> (forall s: Seq.seq Int64.t, i: MutBorrow.t t_Range. produces_back_Range self s i.current
              /\ completed_back_Range i -> UInt64.t'int r.f0 <= Seq.length s)
        /\ match r.f1 with
          | Some r'0 -> forall s: Seq.seq Int64.t, i: t_Range. produces_back_Range self s i
            -> Seq.length s <= UInt64.t'int r'0
          | None -> true
          end)
