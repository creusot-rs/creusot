  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let map_I (iter'0: t_I) (func'0: t_F) (return (x: t_Map_I_F)) =
  {[@stop_split] [@expl:map_I requires] ([@stop_split] [@expl:map 'iter' type invariant] inv_I iter'0)
    /\ ([@stop_split] [@expl:map 'func' type invariant] inv_F func'0)
    /\ ([@stop_split] [@expl:map requires #0] forall e: t_Item, i2: t_I. produces_I iter'0 (Seq.singleton e) i2
          /\ inv_Item e -> precondition_F func'0 e)
    /\ ([@stop_split] [@expl:map requires #1] reinitialize_I)
    /\ ([@stop_split] [@expl:map requires #2] preservation_I iter'0 func'0)}
    (! bb0
    [ bb0 = s0 [ s0 = [ &_ret <- { iter = iter'0; func = func'0 } ] s1 | s1 = return {_ret} ] ]
    [ & _ret: t_Map_I_F = Any.any_l () | & iter'0: t_I = iter'0 | & func'0: t_F = func'0 ])
    [ return (result: t_Map_I_F) ->
    {[@stop_split] [@expl:map_I ensures] ([@stop_split] [@expl:map result type invariant] inv_Map_I_F result)
      /\ ([@stop_split] [@expl:map ensures] result = { iter = iter'0; func = func'0 })}
      (! return {result}) ]
end
