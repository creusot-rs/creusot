module M_calls_f
  use creusot.prelude.Any
  
  let f_i32 (return (x: ())) = any [ return (result: ()) -> (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let calls_f (return (x: ())) = (! bb0
    [ bb0 = s0 [ s0 = f_i32 (fun (_x: ()) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ] [ & _ret: () = Any.any_l () ])
    [ return (result: ()) -> (! return {result}) ]
end
module M_clone_id
  use creusot.prelude.Any
  
  type t_Id
  
  let clone_Id (self: t_Id) (return (x: t_Id)) = any
    [ return (result: t_Id) -> {[@stop_split] [@expl:clone ensures] result = self} (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let clone_id (i: t_Id) (return (x: ())) = (! bb0
    [ bb0 = s0 [ s0 = clone_Id {i} (fun (_x: t_Id) -> [ &_2 <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: () = Any.any_l () | & i: t_Id = i | & _2: t_Id = Any.any_l () ])
    [ return (result: ()) -> (! return {result}) ]
end
module M_impl_Foo_for_i32__f (* <i32 as Foo> *)
  use creusot.prelude.Any
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let f_i32 (return (x: ())) = (! bb0
    [ bb0 = return {_ret} ] [ & _ret: () = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
module M_result
  use creusot.prelude.Any
  
  constant g_i32: int = 1
  
  constant calls_g: int = g_i32
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let result (return (x: ())) = (! bb0
    [ bb0 = s0 [ s0 = {[@expl:assertion] calls_g = 1} s1 | s1 = return {_ret} ] ] [ & _ret: () = Any.any_l () ])
    [ return (result: ()) -> (! return {result}) ]
end
