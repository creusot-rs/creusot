module M_foo
  use creusot.int.UInt32
  use creusot.prelude.Any
  use int.Int
  
  predicate gt_log_u32 [@inline:trivial] (self: UInt32.t) (other: UInt32.t) = UInt32.lt other self
  
  meta "rewrite_def" predicate gt_log_u32
  
  predicate well_founded_relation_u32 [@inline:trivial] (self: UInt32.t) (other: UInt32.t) = gt_log_u32 self other
  
  meta "rewrite_def" predicate well_founded_relation_u32
  
  let new_u32 (x: UInt32.t) (return (x'0: UInt32.t)) = any
    [ return (result: UInt32.t) -> {[@stop_split] [@expl:new ensures] result = x} (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let foo (x: UInt32.t) (return (x'0: UInt32.t)) = (! bb0
    [ bb0 = s0 [ s0 = [ &y <- (0: UInt32.t) ] s1 | s1 = [ &i <- x ] s2 | s2 = bb1 ]
    | bb1 = bb1invariant
      [ bb1 = {[@expl:loop variant] well_founded_relation_u32 variant_old_bb1 i} bb1invariant
      | bb1invariant = {[@expl:loop invariant] UInt32.t'int y + UInt32.t'int i = UInt32.t'int x}
        (! [ &variant_old_bb1 <- i ] s0)
        [ s0 = [ &_16 <- UInt32.gt i (0: UInt32.t) ] s1
        | s1 = any [ br0 -> {_16 = false} (! bb4) | br1 -> {_16} (! bb3) ] ]
        [ bb3 = s0
          [ s0 = UInt32.sub {i} {(1: UInt32.t)} (fun (_x: UInt32.t) -> [ &i <- _x ] s1)
          | s1 = UInt32.add {y} {(1: UInt32.t)} (fun (_x: UInt32.t) -> [ &y <- _x ] s2)
          | s2 = bb1 ] ] ]
    | bb4 = s0 [ s0 = new_u32 {y} (fun (_x: UInt32.t) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: UInt32.t = Any.any_l ()
    | & x: UInt32.t = x
    | & y: UInt32.t = Any.any_l ()
    | & i: UInt32.t = Any.any_l ()
    | & _16: bool = Any.any_l ()
    | & variant_old_bb1: UInt32.t = Any.any_l () ])
    [ return (result: UInt32.t) -> {[@stop_split] [@expl:foo ensures] result = x} (! return {result}) ]
end
