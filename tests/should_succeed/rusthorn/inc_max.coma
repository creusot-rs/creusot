module M_inc_max
  use creusot.prelude.MutBorrow
  use creusot.int.UInt32
  use creusot.prelude.Any
  
  predicate ge_log_u32 [@inline:trivial] (self: UInt32.t) (other: UInt32.t) = UInt32.le other self
  
  meta "rewrite_def" predicate ge_log_u32
  
  let take_max (ma: MutBorrow.t UInt32.t) (mb: MutBorrow.t UInt32.t) (return (x: MutBorrow.t UInt32.t)) = any
    [ return (result: MutBorrow.t UInt32.t) ->
    {[@stop_split] [@expl:take_max ensures] if ge_log_u32 ma.current mb.current then
        mb.current = mb.final /\ result = ma
      else
        ma.current = ma.final /\ result = mb
      }
      (! return {result}) ]
  
  predicate resolve_refmut_u32 [@inline:trivial] (_1: MutBorrow.t UInt32.t) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_u32
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let inc_max (a: UInt32.t) (b: UInt32.t) (return (x: ())) =
  {[@stop_split] [@expl:inc_max requires] UInt32.le a (1000000: UInt32.t) /\ UInt32.le b (1000000: UInt32.t)}
    (! bb0
    [ bb0 = s0
      [ s0 = MutBorrow.borrow_mut <UInt32.t> {a}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_8 <- _bor ] [ &a <- _bor.final ] s1)
      | s1 = MutBorrow.borrow_mut <UInt32.t> {b}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_10 <- _bor ] [ &b <- _bor.final ] s2)
      | s2 = MutBorrow.borrow_final <UInt32.t> {_8.current} {MutBorrow.get_id _8}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_7 <- _bor ] [ &_8 <- { _8 with current = _bor.final } ] s3)
      | s3 = MutBorrow.borrow_final <UInt32.t> {_10.current} {MutBorrow.get_id _10}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_9 <- _bor ] [ &_10 <- { _10 with current = _bor.final } ] s4)
      | s4 = take_max {_7} {_9} (fun (_x: MutBorrow.t UInt32.t) -> [ &mc <- _x ] s5)
      | s5 = -{resolve_refmut_u32 _10}- s6
      | s6 = -{resolve_refmut_u32 _8}- s7
      | s7 = UInt32.add {mc.current} {(1: UInt32.t)} (fun (_x: UInt32.t) -> [ &mc <- { mc with current = _x } ] s8)
      | s8 = -{resolve_refmut_u32 mc}- s9
      | s9 = [ &_12 <- a <> b ] s10
      | s10 = any [ br0 -> {_12 = false} (! bb3) | br1 -> {_12} (! bb2) ] ]
    | bb2 = return {_ret}
    | bb3 = {false} any ]
    [ & _ret: () = Any.any_l ()
    | & a: UInt32.t = a
    | & b: UInt32.t = b
    | & mc: MutBorrow.t UInt32.t = Any.any_l ()
    | & _7: MutBorrow.t UInt32.t = Any.any_l ()
    | & _8: MutBorrow.t UInt32.t = Any.any_l ()
    | & _9: MutBorrow.t UInt32.t = Any.any_l ()
    | & _10: MutBorrow.t UInt32.t = Any.any_l ()
    | & _12: bool = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
module M_take_max
  use creusot.int.UInt32
  use creusot.prelude.MutBorrow
  use creusot.prelude.Any
  
  predicate resolve_refmut_u32 [@inline:trivial] (_1: MutBorrow.t UInt32.t) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_u32
  
  predicate ge_log_u32 [@inline:trivial] (self: UInt32.t) (other: UInt32.t) = UInt32.le other self
  
  meta "rewrite_def" predicate ge_log_u32
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let take_max (ma: MutBorrow.t UInt32.t) (mb: MutBorrow.t UInt32.t) (return (x: MutBorrow.t UInt32.t)) = (! bb0
    [ bb0 = s0
      [ s0 = [ &_8 <- UInt32.ge ma.current mb.current ] s1
      | s1 = any [ br0 -> {_8 = false} (! bb2) | br1 -> {_8} (! bb1) ] ]
    | bb1 = s0
      [ s0 = -{resolve_refmut_u32 mb}- s1
      | s1 = MutBorrow.borrow_final <UInt32.t> {ma.current} {MutBorrow.get_id ma}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_11 <- _bor ] [ &ma <- { ma with current = _bor.final } ] s2)
      | s2 = MutBorrow.borrow_final <UInt32.t> {_11.current} {MutBorrow.get_id _11}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_7 <- _bor ] [ &_11 <- { _11 with current = _bor.final } ] s3)
      | s3 = -{resolve_refmut_u32 _11}- s4
      | s4 = bb3 ]
    | bb2 = s0
      [ s0 = -{resolve_refmut_u32 ma}- s1
      | s1 = MutBorrow.borrow_final <UInt32.t> {mb.current} {MutBorrow.get_id mb}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_7 <- _bor ] [ &mb <- { mb with current = _bor.final } ] s2)
      | s2 = bb3 ]
    | bb3 = s0
      [ s0 = MutBorrow.borrow_final <UInt32.t> {_7.current} {MutBorrow.get_id _7}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_3 <- _bor ] [ &_7 <- { _7 with current = _bor.final } ] s1)
      | s1 = -{resolve_refmut_u32 _7}- s2
      | s2 = MutBorrow.borrow_final <UInt32.t> {_3.current} {MutBorrow.get_id _3}
          (fun (_bor: MutBorrow.t UInt32.t) -> [ &_ret <- _bor ] [ &_3 <- { _3 with current = _bor.final } ] s3)
      | s3 = -{resolve_refmut_u32 _3}- s4
      | s4 = -{resolve_refmut_u32 mb}- s5
      | s5 = -{resolve_refmut_u32 ma}- s6
      | s6 = return {_ret} ] ]
    [ & _ret: MutBorrow.t UInt32.t = Any.any_l ()
    | & ma: MutBorrow.t UInt32.t = ma
    | & mb: MutBorrow.t UInt32.t = mb
    | & _3: MutBorrow.t UInt32.t = Any.any_l ()
    | & _7: MutBorrow.t UInt32.t = Any.any_l ()
    | & _8: bool = Any.any_l ()
    | & _11: MutBorrow.t UInt32.t = Any.any_l () ])
    [ return (result: MutBorrow.t UInt32.t) ->
    {[@stop_split] [@expl:take_max ensures] if ge_log_u32 ma.current mb.current then
        mb.current = mb.final /\ result = ma
      else
        ma.current = ma.final /\ result = mb
      }
      (! return {result}) ]
end
