  use creusot.int.Int32
  use creusot.prelude.Any
  
  type t_Id
  
  type t_Resource  =
    { t_Resource__0: () }
  
  type t_Excl  =
    | C_Excl Int32.t
    | C_Bot
  
  function op (self : t_Excl) (_other : t_Excl) : t_Excl =
    [%#sexcl'8] C_Bot
  
  function associative (a : t_Excl) (b : t_Excl) (c : t_Excl) : ()
  
  axiom associative_spec : forall a : t_Excl, b : t_Excl, c : t_Excl . [%#sexcl'7] op (op a b) c = op a (op b c)
  
  function commutative (a : t_Excl) (b : t_Excl) : ()
  
  axiom commutative_spec : forall a : t_Excl, b : t_Excl . [%#sexcl'6] op a b = op b a
  
  function valid (self : t_Excl) : bool =
    [%#sexcl'9] match self with
      | C_Excl _ -> true
      | C_Bot -> false
      end
  
  function val' (self : t_Resource) : t_Excl
  
  predicate invariant' (self : t_Resource) =
    [%#sresource'8] valid (val' self)
  
  predicate inv (_0 : t_Resource)
  
  axiom inv_axiom [@rewrite] : forall x : t_Resource [inv x] . inv x
  = (invariant' x
  /\ match x with
    | {t_Resource__0 = a_0} -> true
    end)
  
  predicate invariant''0 (self : t_Resource) =
    [%#sinvariant] inv self
  
  predicate inv'0 (_0 : t_Resource)
  
  axiom inv_axiom'0 [@rewrite] : forall x : t_Resource [inv'0 x] . inv'0 x = invariant''0 x
  
  function id (self : t_Resource) : t_Id
  
  let rec id_ghost (self:t_Resource) (return'  (x:t_Id))= {[@expl:id_ghost 'self' type invariant] [%#sresource] inv'0 self}
    any [ return''0 (result:t_Id)-> {[%#sresource'0] result = id self} (! return' {result}) ] 
  
  let rec eq (self:t_Id) (other:t_Id) (return'  (x:bool))= any
    [ return''0 (result:bool)-> {[%#sid] result = (self = other)} (! return' {result}) ]
  
  
  function incl (self : t_Excl) (other : t_Excl) : bool =
    [%#sexcl'5] other = C_Bot
  
  axiom incl_spec : forall self : t_Excl, other : t_Excl . [%#sexcl'4] incl self other
  = (exists c : t_Excl . op self c = other)
  
  function view (self : t_Resource) : t_Excl =
    [%#sresource'7] val' self
  
  function view'0 (self : t_Resource) : t_Excl =
    [%#smodel] view self
  
  let rec join_shared (self:t_Resource) (other:t_Resource) (return'  (x:t_Resource))= {[@expl:join_shared 'self' type invariant] [%#sresource'1] inv'0 self}
    {[@expl:join_shared 'other' type invariant] [%#sresource'2] inv'0 other}
    {[@expl:join_shared requires] [%#sresource'3] id self = id other}
    any
    [ return''0 (result:t_Resource)-> {[%#sresource'4] inv'0 result}
      {[%#sresource'5] id result = id self}
      {[%#sresource'6] incl (view'0 self) (view'0 result) /\ incl (view'0 other) (view'0 result)}
      (! return' {result}) ]
  
  
  meta "compute_max_steps" 1000000
  
  let rec exclusivity[#"excl.rs" 5 0 5 68] (x:t_Resource) (y:t_Resource) (return'  (x'0:()))= {[@expl:exclusivity 'x' type invariant] [%#sexcl'1] inv'0 x}
    {[@expl:exclusivity 'y' type invariant] [%#sexcl'2] inv'0 y}
    (! bb0
    [ bb0 = s0 [ s0 = id_ghost {x'0} (fun (_ret:t_Id) ->  [ &_6 <- _ret ] s1) | s1 = bb1 ] 
    | bb1 = s0 [ s0 = id_ghost {y'0} (fun (_ret:t_Id) ->  [ &_9 <- _ret ] s1) | s1 = bb2 ] 
    | bb2 = s0 [ s0 = eq {_6} {_9} (fun (_ret:bool) ->  [ &_4 <- _ret ] s1) | s1 = bb3 ] 
    | bb3 = any [ br0 -> {_4 = false} (! bb8) | br1 -> {_4} (! bb4) ] 
    | bb4 = s0 [ s0 = join_shared {x'0} {y'0} (fun (_ret:t_Resource) ->  [ &_z <- _ret ] s1) | s1 = bb5 ] 
    | bb5 = any [ br0 -> {([%#sexcl] false) = false} (! bb6) | br1 -> {[%#sexcl] false} (! bb7) ] 
    | bb7 = bb9
    | bb6 = {[%#sexcl'0] false} any
    | bb8 = bb9
    | bb9 = return''0 {_0} ]
    )
    [ & _0 : () = Any.any_l ()
    | & x'0 : t_Resource = x
    | & y'0 : t_Resource = y
    | & _4 : bool = Any.any_l ()
    | & _6 : t_Id = Any.any_l ()
    | & _9 : t_Id = Any.any_l ()
    | & _z : t_Resource = Any.any_l () ]
     [ return''0 (result:())-> {[@expl:exclusivity ensures] [%#sexcl'3] id x <> id y} (! return' {result}) ] 
end
