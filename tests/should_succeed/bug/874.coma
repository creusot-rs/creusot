module M_can_extend
  use creusot.int.Int32
  use creusot.slice.Slice64
  use seq.Seq
  use creusot.int.UInt64
  use creusot.prelude.MutBorrow
  use creusot.prelude.Any
  use int.Int
  
  type t_Vec_i32_Global
  
  constant const_MAX: UInt64.t = (18446744073709551615: UInt64.t)
  
  function view_Vec_i32_Global (self: t_Vec_i32_Global) : Seq.seq Int32.t
  
  axiom view_Vec_i32_Global_spec:
    forall self: t_Vec_i32_Global [view_Vec_i32_Global self]. Seq.length (view_Vec_i32_Global self)
      <= UInt64.t'int const_MAX
  
  function view_Box_slice_i32_Global [@inline:trivial] (self: Slice64.slice Int32.t) : Seq.seq Int32.t =
    Slice64.view self
  
  meta "rewrite_def" function view_Box_slice_i32_Global
  
  let into_vec_i32 (self_: Slice64.slice Int32.t) (return (x: t_Vec_i32_Global)) = any
    [ return (result: t_Vec_i32_Global) -> {[@stop_split] [@expl:into_vec ensures] view_Vec_i32_Global result
      = view_Box_slice_i32_Global self_}
      (! return {result}) ]
  
  predicate precondition_into_iter (self: ()) (args: t_Vec_i32_Global) = let self_ = args in true
  
  meta "rewrite_def" predicate precondition_into_iter
  
  type t_IntoIter_i32_Global
  
  predicate inv_IntoIter_i32_Global (_1: t_IntoIter_i32_Global)
  
  function view_IntoIter_i32_Global (self: t_IntoIter_i32_Global) : Seq.seq Int32.t
  
  let into_iter_Vec_i32_Global (self_: t_Vec_i32_Global) (return (x: t_IntoIter_i32_Global)) = any
    [ return (result: t_IntoIter_i32_Global) ->
    {[@stop_split] [@expl:into_iter_Vec_i32_Global ensures] ([@stop_split] [@expl:into_iter result type invariant] inv_IntoIter_i32_Global result)
      /\ ([@stop_split] [@expl:into_iter ensures] view_Vec_i32_Global self_ = view_IntoIter_i32_Global result)}
      (! return {result}) ]
  
  predicate invariant_refmut_IntoIter_i32_Global [@inline:trivial] (self: MutBorrow.t t_IntoIter_i32_Global) =
    inv_IntoIter_i32_Global self.current /\ inv_IntoIter_i32_Global self.final
  
  meta "rewrite_def" predicate invariant_refmut_IntoIter_i32_Global
  
  predicate inv_refmut_IntoIter_i32_Global [@inline:trivial] (_1: MutBorrow.t t_IntoIter_i32_Global) =
    invariant_refmut_IntoIter_i32_Global _1
  
  meta "rewrite_def" predicate inv_refmut_IntoIter_i32_Global
  
  predicate inv_Seq_i32 [@inline:trivial] (_1: Seq.seq Int32.t) = true
  
  meta "rewrite_def" predicate inv_Seq_i32
  
  predicate postcondition_into_iter (self: ()) (args: t_Vec_i32_Global) (result: t_IntoIter_i32_Global) =
    let self_ = args in inv_IntoIter_i32_Global result /\ view_Vec_i32_Global self_ = view_IntoIter_i32_Global result
  
  meta "rewrite_def" predicate postcondition_into_iter
  
  predicate produces_IntoIter_i32_Global (self: t_IntoIter_i32_Global) (visited: Seq.seq Int32.t) (rhs: t_IntoIter_i32_Global) =
    view_IntoIter_i32_Global self = Seq.(++) visited (view_IntoIter_i32_Global rhs)
  
  function produces_trans_IntoIter_i32_Global (a: t_IntoIter_i32_Global) (ab: Seq.seq Int32.t) (b: t_IntoIter_i32_Global) (bc: Seq.seq Int32.t) (c: t_IntoIter_i32_Global) : ()
  
  axiom produces_trans_IntoIter_i32_Global_spec:
    forall a: t_IntoIter_i32_Global, ab: Seq.seq Int32.t, b: t_IntoIter_i32_Global, bc: Seq.seq Int32.t, c: t_IntoIter_i32_Global. produces_IntoIter_i32_Global a ab b
      -> produces_IntoIter_i32_Global b bc c -> produces_IntoIter_i32_Global a (Seq.(++) ab bc) c
  
  function produces_refl_IntoIter_i32_Global (self: t_IntoIter_i32_Global) : ()
  
  axiom produces_refl_IntoIter_i32_Global_spec:
    forall self: t_IntoIter_i32_Global. produces_IntoIter_i32_Global self (Seq.empty: Seq.seq Int32.t) self
  
  predicate resolve_refmut_IntoIter_i32_Global [@inline:trivial] (_1: MutBorrow.t t_IntoIter_i32_Global) =
    _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_IntoIter_i32_Global
  
  predicate completed_IntoIter_i32_Global (self: MutBorrow.t t_IntoIter_i32_Global) =
    resolve_refmut_IntoIter_i32_Global self /\ view_IntoIter_i32_Global self.current = (Seq.empty: Seq.seq Int32.t)
  
  let extend_Vec_i32_Global (self_: MutBorrow.t t_Vec_i32_Global) (iter: t_Vec_i32_Global) (return (x: ())) =
  {[@stop_split] [@expl:extend requires] precondition_into_iter () iter}
    any
    [ return (result: ()) ->
    {[@stop_split] [@expl:extend ensures] exists start_: t_IntoIter_i32_Global, done': MutBorrow.t t_IntoIter_i32_Global, prod: Seq.seq Int32.t. inv_IntoIter_i32_Global start_
        /\ inv_refmut_IntoIter_i32_Global done'
        /\ inv_Seq_i32 prod
        /\ postcondition_into_iter () iter start_
        /\ completed_IntoIter_i32_Global done'
        /\ produces_IntoIter_i32_Global start_ prod done'.current
        /\ view_Vec_i32_Global self_.final = Seq.(++) (view_Vec_i32_Global self_.current) prod}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let can_extend (return (x: ())) = (! bb0
    [ bb0 = s0
      [ s0 = [ &_4 <- Slice64.of_seq (Seq.create 3 [|(1: Int32.t);(2: Int32.t);(3: Int32.t)|]) ] s1
      | s1 = into_vec_i32 {_4} (fun (_x: t_Vec_i32_Global) -> [ &v <- _x ] s2)
      | s2 = [ &_8 <- Slice64.of_seq (Seq.create 3 [|(4: Int32.t);(5: Int32.t);(6: Int32.t)|]) ] s3
      | s3 = into_vec_i32 {_8} (fun (_x: t_Vec_i32_Global) -> [ &w <- _x ] s4)
      | s4 = MutBorrow.borrow_mut <t_Vec_i32_Global> {v}
          (fun (_bor: MutBorrow.t t_Vec_i32_Global) -> [ &_10 <- _bor ] [ &v <- _bor.final ] s5)
      | s5 = extend_Vec_i32_Global {_10} {w} (fun (_x: ()) -> [ &_9 <- _x ] s6)
      | s6 =
        [ &_15 <- Slice64.of_seq (Seq.create 6 [|(1: Int32.t);(2: Int32.t);(3: Int32.t);(4: Int32.t);(5: Int32.t);(6: Int32.t)|]) ]
        s7
      | s7 = into_vec_i32 {_15} (fun (_x: t_Vec_i32_Global) -> [ &z <- _x ] s8)
      | s8 = {[@expl:assertion] Seq.(==) (view_Vec_i32_Global z) (view_Vec_i32_Global v)} s9
      | s9 = return {_ret} ] ]
    [ & _ret: () = Any.any_l ()
    | & v: t_Vec_i32_Global = Any.any_l ()
    | & _4: Slice64.array Int32.t = Any.any_l ()
    | & w: t_Vec_i32_Global = Any.any_l ()
    | & _8: Slice64.array Int32.t = Any.any_l ()
    | & _9: () = Any.any_l ()
    | & _10: MutBorrow.t t_Vec_i32_Global = Any.any_l ()
    | & z: t_Vec_i32_Global = Any.any_l ()
    | & _15: Slice64.array Int32.t = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
