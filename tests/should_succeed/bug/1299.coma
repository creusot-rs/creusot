  meta "rewrite_def" predicate precondition_closure0
  
  predicate resolve_refmut_Range_isize [@inline:trivial] (_1: MutBorrow.t t_Range_isize) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_Range_isize
  
  predicate completed_Range_isize (self: MutBorrow.t t_Range_isize) =
