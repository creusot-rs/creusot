      | s2 = map_Range_isize {_5} {_7} (fun (_x: t_Map_Range_isize_closure0) -> [ &_4 <- _x ] s3)
      | s3 = s4 [ _ck -> (! {[@expl:type invariant] inv_Map_Range_isize_closure0 _4} any) ]
      | s4 = -{resolve_Map_Range_isize_closure0'0 _4}- s5
