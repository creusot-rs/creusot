  let closure0 [@coma:extspec] (self: MutBorrow.t ()) (j: Int64.t) (return (x: ())) = bb0
    [ bb0 = s0
      [ s0 = -{resolve_refmut_closure0 self}- s1
      | s1 = count_paths {j} (fun (_x: ()) -> [ &_ret <- _x ] s2)
      | s2 = return {_ret} ] ] [ & _ret: () = Any.any_l () | & self: MutBorrow.t () = self | & j: Int64.t = j ]
    [ return (result: ()) -> {[@stop_split] [@expl:closure hist_inv post] hist_inv_closure0 self.current self.final}
