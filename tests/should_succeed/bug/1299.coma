    /\ ge_log_Int (deep_model_isize self.current.start) (deep_model_isize self.current.end')
  
  predicate next_precondition_Range_isize [@inline:trivial] (iter: t_Range_isize) (func: ()) =
    forall e: Int64.t, i: t_Range_isize [produces_Range_isize iter (Seq.singleton e) i]. inv_isize e
        /\ produces_Range_isize iter (Seq.singleton e) i -> precondition_closure0 func e
  
  meta "rewrite_def" predicate next_precondition_Range_isize
  
  predicate inv_Seq_isize [@inline:trivial] (_1: Seq.seq Int64.t) = true
  
  meta "rewrite_def" predicate inv_Seq_isize
  
  predicate inv_refmut_closure0 [@inline:trivial] (_1: MutBorrow.t ()) = true
  
  meta "rewrite_def" predicate inv_refmut_closure0
  
  predicate postcondition_mut_closure0 (self: ()) (args: Int64.t) (result_state: ()) (result: ()) =
    let j = args in exists bor_self: MutBorrow.t (). bor_self.current = self
      /\ bor_self.final = result_state /\ closure0'post'return bor_self j result /\ hist_inv_closure0 self result_state
  
  meta "rewrite_def" predicate postcondition_mut_closure0
  
  predicate preservation_Range_isize [@inline:trivial] (iter: t_Range_isize) (func: ()) =
    forall s: Seq.seq Int64.t, e1: Int64.t, e2: Int64.t, f: MutBorrow.t (), b: (), i: t_Range_isize [produces_Range_isize iter (Seq.snoc (Seq.snoc s e1) e2) i, postcondition_mut_closure0 f.current e1 f.final b]. hist_inv_closure0 func f.current
      -> inv_Seq_isize s /\ inv_isize e1 /\ inv_isize e2 /\ inv_refmut_closure0 f
      -> produces_Range_isize iter (Seq.snoc (Seq.snoc s e1) e2) i
      -> postcondition_mut_closure0 f.current e1 f.final b -> precondition_closure0 f.final e2
  
  meta "rewrite_def" predicate preservation_Range_isize
  
  predicate reinitialize_Range_isize [@inline:trivial] =
    forall iter: MutBorrow.t t_Range_isize, func: (). completed_Range_isize iter
      -> next_precondition_Range_isize iter.final func /\ preservation_Range_isize iter.final func
  
  meta "rewrite_def" predicate reinitialize_Range_isize
  
  predicate inv_Range_isize [@inline:trivial] (_1: t_Range_isize) = true
  
  meta "rewrite_def" predicate inv_Range_isize
  
  function iter_Map_Range_isize_closure0 (self: t_Map_Range_isize_closure0) : t_Range_isize
  
  predicate inv_closure0 [@inline:trivial] (_1: ()) = true
  
  meta "rewrite_def" predicate inv_closure0
  
