module M_f
  use creusot.int.UInt64
  use creusot.prelude.Any
  
  let rec f_usize (x: UInt64.t) (return (x'0: ())) = any [ return (result: ()) -> (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let rec f_T (x: UInt64.t) (return (x'0: ())) = (! bb0
    [ bb0 = s0 [ s0 = [ &_2 <- x = (0: UInt64.t) ] s1 | s1 = any [ br0 -> {_2 = false} (! bb3) | br1 -> {_2} (! bb1) ] ]
    | bb1 = s0 [ s0 = f_usize {(1: UInt64.t)} (fun (_x: ()) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ]
    | bb3 = return {_ret} ] [ & _ret: () = Any.any_l () | & x: UInt64.t = x | & _2: bool = Any.any_l () ])
    [ return (result: ()) -> (! return {result}) ]
end
