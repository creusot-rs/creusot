      /\ postcondition_once_clone'1 () self_.f1 result.f1)}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let clone_unit_leaf (x: tup2_bool_unit) (return (x'0: tup2_bool_unit)) = (! bb0
    [ bb0 = s0 [ s0 = clone_tup2_bool_unit {x} (fun (_x: tup2_bool_unit) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: tup2_bool_unit = Any.any_l () | & x: tup2_bool_unit = x ])
    [ return (result: tup2_bool_unit) -> {[@stop_split] [@expl:clone_unit_leaf ensures] result.f0 = x.f0}
      (! return {result}) ]
end
