module M_range
  use creusot.int.UInt64
  use creusot.prelude.Any
  
  type t_Bound_ref_usize = Included UInt64.t | Excluded UInt64.t | Unbounded
  
  let elim_Excluded (_x: t_Bound_ref_usize) (return (f0: UInt64.t)) = any
    [ _k (f0: UInt64.t) -> {Excluded f0 = _x} (! return {f0})
    | _chk -> (! {[@expl:elim Excluded] match _x with
        | Excluded _ -> true
        | _ -> false
        end}
      any) ]
  
  let elim_Included (_x: t_Bound_ref_usize) (return (f0: UInt64.t)) = any
    [ _k (f0: UInt64.t) -> {Included f0 = _x} (! return {f0})
    | _chk -> (! {[@expl:elim Included] match _x with
        | Included _ -> true
        | _ -> false
        end}
      any) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let range (range: t_Bound_ref_usize) (return (x: UInt64.t)) = (! bb0
    [ bb0 = any
      [ br0 (x0: UInt64.t) -> {range = Included x0} (! bb5)
      | br1 (x0: UInt64.t) -> {range = Excluded x0} (! bb4)
      | br2 -> {range = Unbounded} (! bb1) ]
    | bb4 = s0
      [ s0 = elim_Excluded {range} (fun (r0: UInt64.t) -> [ &end''2 <- r0 ] s1)
      | s1 = [ &_12 <- end''2 = (0: UInt64.t) ] s2
      | s2 = any [ br0 -> {_12 = false} (! bb1) | br1 -> {_12} (! bb8) ] ]
    | bb8 = s0
      [ s0 = elim_Excluded {range} (fun (r0: UInt64.t) -> [ &end''1 <- r0 ] s1)
      | s1 = [ &_ret <- (0: UInt64.t) ] s2
      | s2 = return {_ret} ]
    | bb5 = s0
      [ s0 = elim_Included {range} (fun (r0: UInt64.t) -> [ &end''0 <- r0 ] s1)
      | s1 = [ &_8 <- end''0 = (0: UInt64.t) ] s2
      | s2 = any [ br0 -> {_8 = false} (! bb1) | br1 -> {_8} (! bb6) ] ]
    | bb6 = s0
      [ s0 = elim_Included {range} (fun (r0: UInt64.t) -> [ &end' <- r0 ] s1)
      | s1 = [ &_ret <- (0: UInt64.t) ] s2
      | s2 = return {_ret} ]
    | bb1 = s0 [ s0 = [ &_ret <- (1: UInt64.t) ] s1 | s1 = return {_ret} ] ]
    [ & _ret: UInt64.t = Any.any_l ()
    | & range: t_Bound_ref_usize = range
    | & end': UInt64.t = Any.any_l ()
    | & end''0: UInt64.t = Any.any_l ()
    | & _8: bool = Any.any_l ()
    | & end''1: UInt64.t = Any.any_l ()
    | & end''2: UInt64.t = Any.any_l ()
    | & _12: bool = Any.any_l () ]) [ return (result: UInt64.t) -> (! return {result}) ]
end
