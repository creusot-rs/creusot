module M_cast
  use creusot.int.UInt32
  use creusot.int.UInt8
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  constant x : UInt32.t
  
  function cast (x: UInt32.t) : UInt8.t
  
  goal vc_cast: [@stop_split] [@expl:cast ensures] UInt8.of_int (UInt32.t'int x) = UInt8.of_int (UInt32.t'int x)
end
