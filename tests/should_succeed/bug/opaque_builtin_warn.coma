module M_clone_closure
  use creusot.int.UInt32
  use creusot.prelude.Any
  
  type closure0 = { c0: UInt32.t }
  
  let closure0 [@coma:extspec] (self: closure0) (y: UInt32.t) (return (x: UInt32.t)) = bb0
    [ bb0 = s0 [ s0 = UInt32.add {self.c0} {y} (fun (_x: UInt32.t) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: UInt32.t = Any.any_l () | & self: closure0 = self | & y: UInt32.t = y ]
    [ return (result: UInt32.t) -> return {result} ]
  
  meta "rewrite_def" predicate closure0'pre
  
  meta "rewrite_def" predicate closure0'post'return
  
  predicate precondition_clone (self: ()) (args: closure0)
  
  axiom precondition_fndef: forall args: closure0 [precondition_clone () args]. (let self_ = args in true)
      -> precondition_clone () args
  
  predicate postcondition_once_clone (self: ()) (args: closure0) (result: closure0)
  
  axiom postcondition_fndef:
    forall args: closure0, res: closure0 [postcondition_once_clone () args res]. postcondition_once_clone () args res
      -> (let self_ = args in true)
  
  let clone_closure0 (self_: closure0) (return (x: closure0)) =
  {[@stop_split] [@expl:clone requires] precondition_clone () self_}
    any
    [ return (result: closure0) -> {[@stop_split] [@expl:clone ensures] postcondition_once_clone () self_ result}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let clone_closure (x: UInt32.t) (return (x'0: closure0)) = (! bb0
    [ bb0 = s0
      [ s0 = [ &f <- { c0 = x } ] s1
      | s1 = clone_closure0 {f} (fun (_x: closure0) -> [ &_ret <- _x ] s2)
      | s2 = return {_ret} ] ] [ & _ret: closure0 = Any.any_l () | & x: UInt32.t = x | & f: closure0 = Any.any_l () ])
    [ return (result: closure0) -> (! return {result}) ]
end
module M_clone_tuple_with_closure
  use creusot.int.UInt32
  use creusot.prelude.Any
  
  type closure0 = { c0: UInt32.t }
  
  let closure0 [@coma:extspec] (self: closure0) (y: UInt32.t) (return (x: UInt32.t)) = bb0
    [ bb0 = s0 [ s0 = UInt32.add {self.c0} {y} (fun (_x: UInt32.t) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: UInt32.t = Any.any_l () | & self: closure0 = self | & y: UInt32.t = y ]
    [ return (result: UInt32.t) -> return {result} ]
  
  meta "rewrite_def" predicate closure0'pre
  
  meta "rewrite_def" predicate closure0'post'return
  
  type tup2_bool_closure0 = { f0: bool; f1: closure0 }
  
  predicate precondition_clone (self: ()) (args: tup2_bool_closure0)
  
  axiom precondition_fndef: forall args: tup2_bool_closure0 [precondition_clone () args]. (let self_ = args in true)
      -> precondition_clone () args
  
  predicate postcondition_once_clone (self: ()) (args: tup2_bool_closure0) (result: tup2_bool_closure0)
  
  axiom postcondition_fndef:
    forall args: tup2_bool_closure0, res: tup2_bool_closure0 [postcondition_once_clone () args res]. postcondition_once_clone () args res
      -> (let self_ = args in true)
  
  predicate postcondition_once_clone'0 (self: ()) (args: bool) (result: bool) = let self_ = args in result = self_
  
  meta "rewrite_def" predicate postcondition_once_clone'0
  
  predicate postcondition_once_clone'1 (self: ()) (args: closure0) (result: closure0)
  
  axiom postcondition_fndef'0:
    forall args: closure0, res: closure0 [postcondition_once_clone'1 () args res]. postcondition_once_clone'1 () args res
      -> (let self_ = args in true)
  
  let clone_tup2_bool_closure0 (self_: tup2_bool_closure0) (return (x: tup2_bool_closure0)) =
  {[@stop_split] [@expl:clone requires] precondition_clone () self_}
    any
    [ return (result: tup2_bool_closure0) ->
    {[@stop_split] [@expl:clone_tup2_bool_closure0 ensures] ([@stop_split] [@expl:clone ensures] postcondition_once_clone () self_ result)
      /\ ([@stop_split] [@expl:clone ensures] postcondition_once_clone'0 () self_.f0 result.f0
      /\ postcondition_once_clone'1 () self_.f1 result.f1)}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let clone_tuple_with_closure (b: bool) (x: UInt32.t) (return (x'0: tup2_bool_closure0)) = (! bb0
    [ bb0 = s0
      [ s0 = [ &_5 <- { c0 = x } ] s1
      | s1 = [ &t <- { f0 = b; f1 = _5 } ] s2
      | s2 = clone_tup2_bool_closure0 {t} (fun (_x: tup2_bool_closure0) -> [ &_ret <- _x ] s3)
      | s3 = return {_ret} ] ]
    [ & _ret: tup2_bool_closure0 = Any.any_l ()
    | & b: bool = b
    | & x: UInt32.t = x
    | & t: tup2_bool_closure0 = Any.any_l ()
    | & _5: closure0 = Any.any_l () ]) [ return (result: tup2_bool_closure0) -> (! return {result}) ]
end
