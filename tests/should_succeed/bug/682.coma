module M_add_some
  use creusot.int.UInt64
  use creusot.prelude.MutBorrow
  use creusot.prelude.Any
  use int.ComputerDivision
  use int.Int
  
  predicate resolve_refmut_u64 [@inline:trivial] (_1: MutBorrow.t UInt64.t) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_u64
  
  constant const_MAX: UInt64.t = (18446744073709551615: UInt64.t)
  
  type t_Ordering = Less | Equal | Greater
  
  type t_Option_Ordering = None | Some t_Ordering
  
  function partial_cmp_log_u64 (self: UInt64.t) (o: UInt64.t) : t_Option_Ordering = if UInt64.lt self o then
      Some (Less)
    else
      if self = o then Some (Equal) else Some (Greater)
  
  
  function eq_partial_cmp_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom eq_partial_cmp_u64_spec: forall x: UInt64.t, y: UInt64.t. (x = y) = (partial_cmp_log_u64 x y = Some (Equal))
  
  function asymetric2_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom asymetric2_u64_spec: forall x: UInt64.t, y: UInt64.t. partial_cmp_log_u64 x y = Some (Greater)
      -> partial_cmp_log_u64 y x = Some (Less)
  
  function asymetric1_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom asymetric1_u64_spec: forall x: UInt64.t, y: UInt64.t. partial_cmp_log_u64 x y = Some (Less)
      -> partial_cmp_log_u64 y x = Some (Greater)
  
  function trans_u64 (x: UInt64.t) (y: UInt64.t) (z: UInt64.t) (o: t_Option_Ordering) : ()
  
  axiom trans_u64_spec: forall x: UInt64.t, y: UInt64.t, z: UInt64.t, o: t_Option_Ordering. partial_cmp_log_u64 x y = o
      -> partial_cmp_log_u64 y z = o -> partial_cmp_log_u64 x z = o
  
  function refl_u64 (x: UInt64.t) : ()
  
  axiom refl_u64_spec: forall x: UInt64.t. partial_cmp_log_u64 x x = Some (Equal)
  
  function partial_cmp_gt_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_gt_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.gt x y
      = (partial_cmp_log_u64 x y = Some (Greater))
  
  function partial_cmp_ge_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_ge_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.ge x y
      = (partial_cmp_log_u64 x y = Some (Greater) \/ partial_cmp_log_u64 x y = Some (Equal))
  
  function partial_cmp_lt_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_lt_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.lt x y
      = (partial_cmp_log_u64 x y = Some (Less))
  
  function partial_cmp_le_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_le_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.le x y
      = (partial_cmp_log_u64 x y = Some (Less) \/ partial_cmp_log_u64 x y = Some (Equal))
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let add_some (a: MutBorrow.t UInt64.t) (return (x: ())) =
  {[@stop_split] [@expl:add_some requires] UInt64.t'int a.current <= ComputerDivision.div (UInt64.t'int const_MAX) 2}
    (! bb0
    [ bb0 = s0
      [ s0 = UInt64.add {a.current} {(1: UInt64.t)} (fun (_x: UInt64.t) -> [ &a <- { a with current = _x } ] s1)
      | s1 = -{resolve_refmut_u64 a}- s2
      | s2 = return {_ret} ] ] [ & _ret: () = Any.any_l () | & a: MutBorrow.t UInt64.t = a ])
    [ return (result: ()) -> {[@stop_split] [@expl:add_some ensures] UInt64.gt a.final a.current} (! return {result}) ]
end
module M_foo
  use creusot.prelude.MutBorrow
  use creusot.int.UInt64
  use int.ComputerDivision
  use creusot.prelude.Any
  use int.Int
  
  constant const_MAX: UInt64.t = (18446744073709551615: UInt64.t)
  
  type t_Ordering = Less | Equal | Greater
  
  type t_Option_Ordering = None | Some t_Ordering
  
  function partial_cmp_log_u64 (self: UInt64.t) (o: UInt64.t) : t_Option_Ordering = if UInt64.lt self o then
      Some (Less)
    else
      if self = o then Some (Equal) else Some (Greater)
  
  
  function eq_partial_cmp_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom eq_partial_cmp_u64_spec: forall x: UInt64.t, y: UInt64.t. (x = y) = (partial_cmp_log_u64 x y = Some (Equal))
  
  function asymetric2_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom asymetric2_u64_spec: forall x: UInt64.t, y: UInt64.t. partial_cmp_log_u64 x y = Some (Greater)
      -> partial_cmp_log_u64 y x = Some (Less)
  
  function asymetric1_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom asymetric1_u64_spec: forall x: UInt64.t, y: UInt64.t. partial_cmp_log_u64 x y = Some (Less)
      -> partial_cmp_log_u64 y x = Some (Greater)
  
  function trans_u64 (x: UInt64.t) (y: UInt64.t) (z: UInt64.t) (o: t_Option_Ordering) : ()
  
  axiom trans_u64_spec: forall x: UInt64.t, y: UInt64.t, z: UInt64.t, o: t_Option_Ordering. partial_cmp_log_u64 x y = o
      -> partial_cmp_log_u64 y z = o -> partial_cmp_log_u64 x z = o
  
  function refl_u64 (x: UInt64.t) : ()
  
  axiom refl_u64_spec: forall x: UInt64.t. partial_cmp_log_u64 x x = Some (Equal)
  
  function partial_cmp_gt_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_gt_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.gt x y
      = (partial_cmp_log_u64 x y = Some (Greater))
  
  function partial_cmp_ge_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_ge_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.ge x y
      = (partial_cmp_log_u64 x y = Some (Greater) \/ partial_cmp_log_u64 x y = Some (Equal))
  
  function partial_cmp_lt_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_lt_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.lt x y
      = (partial_cmp_log_u64 x y = Some (Less))
  
  function partial_cmp_le_log_u64 (x: UInt64.t) (y: UInt64.t) : ()
  
  axiom partial_cmp_le_log_u64_spec: forall x: UInt64.t, y: UInt64.t. UInt64.le x y
      = (partial_cmp_log_u64 x y = Some (Less) \/ partial_cmp_log_u64 x y = Some (Equal))
  
  let add_some (a: MutBorrow.t UInt64.t) (return (x: ())) =
  {[@stop_split] [@expl:add_some requires] UInt64.t'int a.current <= ComputerDivision.div (UInt64.t'int const_MAX) 2}
    any
    [ return (result: ()) -> {[@stop_split] [@expl:add_some ensures] UInt64.gt a.final a.current} (! return {result}) ]
  
  predicate resolve_refmut_u64 [@inline:trivial] (_1: MutBorrow.t UInt64.t) = _1.final = _1.current
  
  meta "rewrite_def" predicate resolve_refmut_u64
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let foo (a: MutBorrow.t UInt64.t) (return (x: ())) = {[@stop_split] [@expl:foo requires] a.current = (3: UInt64.t)}
    (! bb0
    [ bb0 = s0
      [ s0 = [ &a_p <- a.current ] s1
      | s1 = MutBorrow.borrow_final <UInt64.t> {a.current} {MutBorrow.get_id a}
          (fun (_bor: MutBorrow.t UInt64.t) -> [ &_10 <- _bor ] [ &a <- { a with current = _bor.final } ] s2)
      | s2 = add_some {_10} (fun (_x: ()) -> [ &_9 <- _x ] s3)
      | s3 = -{resolve_refmut_u64 a}- s4
      | s4 = {[@expl:assertion] UInt64.gt a.current a_p} s5
      | s5 = return {_ret} ] ]
    [ & _ret: () = Any.any_l ()
    | & a: MutBorrow.t UInt64.t = a
    | & a_p: UInt64.t = Any.any_l ()
    | & _9: () = Any.any_l ()
    | & _10: MutBorrow.t UInt64.t = Any.any_l () ])
    [ return (result: ()) -> {[@stop_split] [@expl:foo ensures] UInt64.gt a.final a.current} (! return {result}) ]
end
