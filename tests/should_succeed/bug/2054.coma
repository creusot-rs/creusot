module M_f
  use creusot.prelude.Any
  
  type t_T
  
  type t_S_T = { f0: t_T }
  
  predicate inv_T (_1: t_T)
  
  predicate inv_S_T (_1: t_S_T)
  
  axiom inv_axiom [@rewrite]: forall x: t_S_T [inv_S_T x]. inv_S_T x = inv_T x.f0
  
  constant const_C : t_T
  
  axiom const_C_spec: inv_T const_C
  
  constant const_C'0 : t_S_T
  
  axiom const_C_spec'0: inv_S_T const_C'0
  
  let rec set_C (return) = bb0
    [ bb0 = s0
      [ s0 = bb0'0
        [ bb0'0 = s0'0 [ s0'0 = [ &_ret'0 <- { f0 = const_C } ] s1'0 | s1'0 = _const_ret {_ret'0} ] ]
        [ & _ret'0: t_S_T = Any.any_l () ] [ _const_ret (_const: t_S_T) -> [ &_ret <- _const ] s1 ]
      | s1 = return {_ret} ] ] [ & _ret: t_S_T = Any.any_l () ]
    [ return (_const: t_S_T) -> -{const_C'0 = _const}- return ]
  
  constant const_C'1 : t_S_T
  
  axiom const_C_spec'1: inv_S_T const_C'1
  
  let rec set_C'0 (return) = bb0
    [ bb0 = s0
      [ s0 = bb0'0
        [ bb0'0 = s0'0 [ s0'0 = [ &_ret'0 <- { f0 = const_C } ] s1'0 | s1'0 = _const_ret {_ret'0} ] ]
        [ & _ret'0: t_S_T = Any.any_l () ] [ _const_ret (_const: t_S_T) -> [ &_ret <- _const ] s1 ]
      | s1 = return {_ret} ] ] [ & _ret: t_S_T = Any.any_l () ]
    [ return (_const: t_S_T) -> -{const_C'1 = _const}- return ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let rec f_T (return (x: t_S_T)) = (! set_C'0
      (set_C
        (bb0
        [ bb0 = s0 [ s0 = [ &_ret <- const_C'0 ] s1 | s1 = return {_ret} ] ] [ & _ret: t_S_T = Any.any_l () ])))
    [ return (result: t_S_T) ->
    {[@stop_split] [@expl:f_T ensures] ([@stop_split] [@expl:f result type invariant] inv_S_T result)
      /\ ([@stop_split] [@expl:f ensures] result = const_C'1)}
      (! return {result}) ]
end
