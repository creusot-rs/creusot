module M_f
  use mach.int.Int
  use creusot.prelude.Any
  
  type t_Arguments
  
  predicate inv_Arguments (_1: t_Arguments)
  
  let rec from_str (s: string) (return (x: t_Arguments)) = any
    [ return (result: t_Arguments) -> {inv_Arguments result} (! return {result}) ]
  
  let rec _print (args: t_Arguments) (return (x: ())) = {[@expl:_print 'args' type invariant] inv_Arguments args}
    any [ return (result: ()) -> {true} (! return {result}) ]
  
  let rec _eprint (args: t_Arguments) (return (x: ())) = {[@expl:_eprint 'args' type invariant] inv_Arguments args}
    any [ return (result: ()) -> {true} (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let rec f (return (x: ())) = (! bb0
    [ bb0 = s0 [ s0 = from_str {"Hello "} (fun (_ret: t_Arguments) -> [ &_3 <- _ret ] s1) | s1 = bb1 ]
    | bb1 = s0 [ s0 = _print {_3} (fun (_ret: ()) -> [ &_2 <- _ret ] s1) | s1 = bb2 ]
    | bb2 = s0 [ s0 = from_str {"world!\n"} (fun (_ret: t_Arguments) -> [ &_6 <- _ret ] s1) | s1 = bb3 ]
    | bb3 = s0 [ s0 = _print {_6} (fun (_ret: ()) -> [ &_5 <- _ret ] s1) | s1 = bb4 ]
    | bb4 = s0 [ s0 = from_str {"Hello "} (fun (_ret: t_Arguments) -> [ &_9 <- _ret ] s1) | s1 = bb5 ]
    | bb5 = s0 [ s0 = _eprint {_9} (fun (_ret: ()) -> [ &_8 <- _ret ] s1) | s1 = bb6 ]
    | bb6 = s0 [ s0 = from_str {"stderr!\n"} (fun (_ret: t_Arguments) -> [ &_12 <- _ret ] s1) | s1 = bb7 ]
    | bb7 = s0 [ s0 = _eprint {_12} (fun (_ret: ()) -> [ &_11 <- _ret ] s1) | s1 = bb8 ]
    | bb8 = s0 [ s0 = {[@expl:assertion] 1 + 1 = 2} s1 | s1 = return {_0} ] ]
    [ & _0: () = Any.any_l ()
    | & _2: () = Any.any_l ()
    | & _3: t_Arguments = Any.any_l ()
    | & _5: () = Any.any_l ()
    | & _6: t_Arguments = Any.any_l ()
    | & _8: () = Any.any_l ()
    | & _9: t_Arguments = Any.any_l ()
    | & _11: () = Any.any_l ()
    | & _12: t_Arguments = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
