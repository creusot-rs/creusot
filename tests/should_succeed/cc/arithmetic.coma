module M_bitand_ref
  use creusot.int.UInt8BW
  use creusot.prelude.Any
  use int.Int
  
  let bitand_ref_u8 (self_: UInt8BW.t) (rhs: UInt8BW.t) (return (x: UInt8BW.t)) = any
    [ return (result: UInt8BW.t) -> {[@stop_split] [@expl:bitand ensures] result = UInt8BW.bw_and self_ rhs}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let bitand_ref (a: UInt8BW.t) (return (x: UInt8BW.t)) = (! bb0
    [ bb0 = s0
      [ s0 = bitand_ref_u8 {a} {(15: UInt8BW.t)} (fun (_x: UInt8BW.t) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: UInt8BW.t = Any.any_l () | & a: UInt8BW.t = a ])
    [ return (result: UInt8BW.t) ->
    {[@stop_split] [@expl:bitand_ref ensures] ([@stop_split] [@expl:bitand_ref ensures #0] result
        = UInt8BW.bw_and a (15: UInt8BW.t))
      /\ ([@stop_split] [@expl:bitand_ref ensures #1] UInt8BW.t'int result <= 15)}
      (! return {result}) ]
end
module M_shr_ref
  use creusot.int.UInt8BW
  use creusot.int.Int32BW
  use creusot.int.UInt64BW
  use creusot.int.UInt32BW
  use creusot.prelude.Any
  
  type t_Ordering = Less | Equal | Greater
  
  type t_Option_Ordering = None | Some t_Ordering
  
  function partial_cmp_log_i32 (self: Int32BW.t) (o: Int32BW.t) : t_Option_Ordering = if Int32BW.lt self o then
      Some (Less)
    else
      if self = o then Some (Equal) else Some (Greater)
  
  
  function eq_partial_cmp_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom eq_partial_cmp_i32_spec: forall x: Int32BW.t, y: Int32BW.t. (x = y) = (partial_cmp_log_i32 x y = Some (Equal))
  
  function asymetric2_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom asymetric2_i32_spec: forall x: Int32BW.t, y: Int32BW.t. partial_cmp_log_i32 x y = Some (Greater)
      -> partial_cmp_log_i32 y x = Some (Less)
  
  function asymetric1_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom asymetric1_i32_spec: forall x: Int32BW.t, y: Int32BW.t. partial_cmp_log_i32 x y = Some (Less)
      -> partial_cmp_log_i32 y x = Some (Greater)
  
  function trans_i32 (x: Int32BW.t) (y: Int32BW.t) (z: Int32BW.t) (o: t_Option_Ordering) : ()
  
  axiom trans_i32_spec: forall x: Int32BW.t, y: Int32BW.t, z: Int32BW.t, o: t_Option_Ordering. partial_cmp_log_i32 x y
        = o -> partial_cmp_log_i32 y z = o -> partial_cmp_log_i32 x z = o
  
  function refl_i32 (x: Int32BW.t) : ()
  
  axiom refl_i32_spec: forall x: Int32BW.t. partial_cmp_log_i32 x x = Some (Equal)
  
  function partial_cmp_gt_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom partial_cmp_gt_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.gt x y
      = (partial_cmp_log_i32 x y = Some (Greater))
  
  function partial_cmp_ge_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom partial_cmp_ge_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.ge x y
      = (partial_cmp_log_i32 x y = Some (Greater) \/ partial_cmp_log_i32 x y = Some (Equal))
  
  function partial_cmp_lt_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom partial_cmp_lt_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.lt x y
      = (partial_cmp_log_i32 x y = Some (Less))
  
  function partial_cmp_le_log_i32 (x: Int32BW.t) (y: Int32BW.t) : ()
  
  axiom partial_cmp_le_log_i32_spec: forall x: Int32BW.t, y: Int32BW.t. Int32BW.le x y
      = (partial_cmp_log_i32 x y = Some (Less) \/ partial_cmp_log_i32 x y = Some (Equal))
  
  constant const_BITS: UInt32BW.t = (8: UInt32BW.t)
  
  let shr_ref_u8 (self_: UInt8BW.t) (rhs: Int32BW.t) (return (x: UInt8BW.t)) =
  {[@stop_split] [@expl:shr requires] Int32BW.le (Int32BW.of_BV256 (UInt64BW.to_BV256 (0: UInt64BW.t))) rhs
    /\ Int32BW.lt rhs const_BITS}
    any
    [ return (result: UInt8BW.t) -> {[@stop_split] [@expl:shr ensures] result
      = UInt8BW.shr self_ (UInt8BW.of_BV256 (Int32BW.to_BV256 rhs))}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let shr_ref (a: UInt8BW.t) (return (x: UInt8BW.t)) = (! bb0
    [ bb0 = s0
      [ s0 = shr_ref_u8 {a} {(1: Int32BW.t)} (fun (_x: UInt8BW.t) -> [ &_ret <- _x ] s1) | s1 = return {_ret} ] ]
    [ & _ret: UInt8BW.t = Any.any_l () | & a: UInt8BW.t = a ])
    [ return (result: UInt8BW.t) -> {[@stop_split] [@expl:shr_ref ensures] result
      = UInt8BW.shr a (UInt8BW.of_BV256 (UInt64BW.to_BV256 (1: UInt64BW.t)))}
      (! return {result}) ]
end
module M_test
  use creusot.int.UInt8BW
  use creusot.prelude.Any
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let test (return (x: ())) = (! bb0
    [ bb0 = s0
      [ s0 = {[@expl:assertion] UInt8BW.nth (0: UInt8BW.t) 42 = false} s1
      | s1 = {[@expl:assertion] UInt8BW.nth (42: UInt8BW.t) 0 = false} s2
      | s2 = {[@expl:assertion] UInt8BW.nth (42: UInt8BW.t) 1 = true} s3
      | s3 = return {_ret} ] ] [ & _ret: () = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
