module M_f
  use creusot.prelude.Any
  
  type t_T
  
  type closure1 = { c0: t_T }
  
  predicate inv_T (_1: t_T)
  
  predicate inv_closure1 [@inline:trivial] (_1: closure1) = let {c0 = x0} = _1 in inv_T x0
  
  meta "rewrite_def" predicate inv_closure1
  
  predicate invariant_ref_closure1 [@inline:trivial] (self: closure1) = inv_closure1 self
  
  meta "rewrite_def" predicate invariant_ref_closure1
  
  predicate inv_ref_closure1 [@inline:trivial] (_1: closure1) = invariant_ref_closure1 _1
  
  meta "rewrite_def" predicate inv_ref_closure1
  
  let closure1 (self: closure1) (return (x: ())) =
  {[@stop_split] [@expl:closure 'self' type invariant] inv_ref_closure1 self}
    (! bb0
    [ bb0 = return {_ret} ] [ & _ret: () = Any.any_l () | & self: closure1 = self ])
    [ return (result: ()) -> (! return {result}) ]
  
  predicate resolve_T (_1: t_T)
  
  predicate postcondition_once_closure1 (self: closure1) (args: ()) (result: ()) = resolve_T self.c0
  
  meta "rewrite_def" predicate postcondition_once_closure1
  
  predicate resolve_closure1 [@inline:trivial] (_1: closure1) = resolve_T _1.c0
  
  meta "rewrite_def" predicate resolve_closure1
  
  predicate precondition_closure1 (self: closure1) (args: ()) = true
  
  meta "rewrite_def" predicate precondition_closure1
  
  predicate postcondition_closure1 (self: closure1) (args: ()) (result: ()) = true
  
  meta "rewrite_def" predicate postcondition_closure1
  
  let call_closure1 (self_: closure1) (arg: ()) (return (x: ())) =
  {[@stop_split] [@expl:call_closure1 requires] ([@stop_split] [@expl:call 'self_' type invariant] inv_ref_closure1 self_)
    /\ ([@stop_split] [@expl:call requires] precondition_closure1 self_ arg)}
    any
    [ return (result: ()) -> {[@stop_split] [@expl:call ensures] postcondition_closure1 self_ arg result}
      (! return {result}) ]
  
  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let f_T (x: t_T) (return (x'0: ())) = {[@stop_split] [@expl:f 'x' type invariant] inv_T x}
    (! bb0
    [ bb0 = s0
      [ s0 = [ &xx <- x ] s1
      | s1 = [ &f <- { c0 = x } ] s2
      | s2 = {[@expl:assertion] postcondition_once_closure1 f () () -> resolve_T xx} s3
      | s3 = s4 [ _ck -> (! {[@expl:type invariant] inv_closure1 f} any) ]
      | s4 = -{resolve_closure1 f}- s5
      | s5 = call_closure1 {f} {_11} (fun (_x: ()) -> [ &_ret <- _x ] s6)
      | s6 = return {_ret} ] ]
    [ & _ret: () = Any.any_l ()
    | & x: t_T = x
    | & xx: t_T = Any.any_l ()
    | & f: closure1 = Any.any_l ()
    | & _11: () = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
