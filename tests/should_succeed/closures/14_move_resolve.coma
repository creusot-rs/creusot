  meta "compute_max_steps" 1000000
  
  meta "select_lsinst" "all"
  
  let g_T (x: t_T) (return (x'0: ())) = {[@stop_split] [@expl:g 'x' type invariant] inv_T x}
    (! bb0
    [ bb0 = s0
      [ s0 = [ &xx <- x ] s1
      | s1 = [ &f <- { c0 = x } ] s2
      | s2 = {[@expl:assertion] postcondition_once_closure0 f () () -> resolve_T xx} s3
      | s3 = s4 [ _ck -> (! {[@expl:type invariant] inv_closure0 f} any) ]
      | s4 = -{resolve_closure0 f}- s5
      | s5 = call_closure0 {f} {_11} (fun (_x: ()) -> [ &_ret <- _x ] s6)
      | s6 = return {_ret} ] ]
    [ & _ret: () = Any.any_l ()
    | & x: t_T = x
    | & xx: t_T = Any.any_l ()
    | & f: closure0 = Any.any_l ()
    | & _11: () = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
end
