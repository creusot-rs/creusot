
module Unnest_Unnest
  use prelude.Intrinsic
  use prelude.Borrow
  use prelude.UInt32
  use prelude.Int
  predicate resolve1 (self : borrowed uint32) =
    [#"../../../../creusot-contracts/src/resolve.rs" 25 20 25 34]  ^ self =  * self
  let rec resolve1 (self:borrowed uint32) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = resolve1 self} (! return' {result}) ]
    
  predicate resolve0 (self : borrowed (borrowed uint32)) =
    [#"../../../../creusot-contracts/src/resolve.rs" 25 20 25 34]  ^ self =  * self
  let rec resolve0 (self:borrowed (borrowed uint32)) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = resolve0 self} (! return' {result}) ]
    
  let rec unnest (x:borrowed (borrowed uint32)) (return'  (ret:borrowed uint32))= (! bb0 
    [ bb0 = Borrow.borrow_mut <uint32> { *  * x} (fun (_ret':borrowed uint32) -> 
        [ &x <- { x with current = { ( * x) with current = ( ^ _2) ; } ; } ]
        [ &_2 <- _ret' ] Borrow.borrow_final <uint32> { * _2} {Borrow.get_id _2} (fun (_ret':borrowed uint32) -> 
          [ &_0 <- _ret' ]
          [ &_2 <- { _2 with current = ( ^ _0) ; } ] -{resolve1 _2}- -{resolve0 x}- return' {_0})) ]
    )
    [ & _0 : borrowed uint32 = any_l () : borrowed uint32
    | & x : borrowed (borrowed uint32) = x
    | & _2 : borrowed uint32 = any_l () : borrowed uint32 ]
     
    [ return' (result:borrowed uint32)-> {[#"../unnest.rs" 7 10 7 20]  ^  * x =  ^  ^ x}
      {[#"../unnest.rs" 6 10 6 24]  ^ result =  *  ^ x}
      {[#"../unnest.rs" 5 10 5 24]  * result =  *  * x}
      (! return' {result}) ]
    
end
