
module SwitchStruct_M_Type
  use prelude.UInt32
  use prelude.Int
  type t_m 't =
    | C_F uint32
    | C_G 't
    
  function any_l (_ : 'b) : 'a
  function f_field1 (self : t_m 't) : uint32 =
    match self with
      | C_F a -> a
      | C_G _ -> any_l self
      end
  function g_field2 (self : t_m 't) : 't =
    match self with
      | C_F _ -> any_l self
      | C_G a -> a
      end
end
module SwitchStruct_Test
  use prelude.Intrinsic
  use prelude.UInt32
  use SwitchStruct_M_Type as SwitchStruct_M_Type
  use prelude.Int
  let rec test (o:SwitchStruct_M_Type.t_m uint32) (return'  (ret:bool))= (! bb0 
    [ bb5 = return' {_0} 
    | bb4 = [ &field1 <- SwitchStruct_M_Type.f_field1 o ] UInt32.gt {field1}
      {[#"../switch_struct.rs" 11 33 11 34] (0 : uint32)} (fun (_ret':bool) -> [ &_0 <- _ret' ] bb5) 
    | bb1 = bb4 
    | bb2 = [ &field2 <- SwitchStruct_M_Type.g_field2 o ] UInt32.eq {field2}
      {[#"../switch_struct.rs" 12 34 12 35] (0 : uint32)} (fun (_ret':bool) -> [ &_0 <- _ret' ] bb5) 
    | bb3 = {[#"../switch_struct.rs" 10 10 10 11] false}
      any 
    | bb0 = any 
      [ br0 (a:uint32)-> {o = SwitchStruct_M_Type.C_F a}
        (! bb1)
      | br1 (a:uint32)-> {o = SwitchStruct_M_Type.C_G a}
        (! bb2)
      | default -> (! bb3) ]
        ]
    ) [ return' (result:bool)-> (! return' {_0}) ] 
    [ & _0 : bool = any_l () : bool
    | & o : SwitchStruct_M_Type.t_m uint32 = o
    | & field1 : uint32 = any_l () : uint32
    | & field2 : uint32 = any_l () : uint32 ]
    
end
