end
module Core_Result_Result_Type
  type t_result 't 'e =
    | C_Ok 't
    | C_Err 'e
    
  function any_l (_ : 'b) : 'a
  let rec ok < 't > < 'e > (input:t_result 't 'e) (ret  (field_0:'t))= any 
    [ good (field_0:'t)-> {C_Ok field_0 = input}
      ret {field_0}
    | bad (field_0:'t)-> {C_Ok field_0 <> input}
      {false}
      any ]
    
  let rec err < 't > < 'e > (input:t_result 't 'e) (ret  (field_0:'e))= any 
    [ good (field_0:'e)-> {C_Err field_0 = input}
      ret {field_0}
    | bad (field_0:'e)-> {C_Err field_0 <> input}
      {false}
      any ]
    
end
