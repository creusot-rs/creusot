  let rec copy_out_of_ref (x:uint32) (return'  (ret:uint32))= (! bb0 [ bb0 = [ &_0 <- x ] return' {_0} ] )
    [ & _0 : uint32 = any_l () : uint32 | & x : uint32 = x ]
