  use prelude.UInt32
  let rec divide (y:uint32) (x:uint32) (return'  (ret:uint32))= {[#"../division.rs" 5 11 5 20] x <> (0 : uint32)}
    (! bb0 
    [ bb1 = UInt32.div {y} {_5} (fun (_ret':uint32) -> [ &_0 <- _ret' ] return' {_0}) 
    | bb0 = [ &_5 <- x ] UInt32.eq {_5} {[#"../division.rs" 7 4 7 9] (0 : uint32)} (fun (_ret':bool) -> 
        [ &_6 <- _ret' ]
        {[@expl:division by zero] [#"../division.rs" 7 4 7 9] not _6}
        bb1)  ]
    ) [ return' (result:uint32)-> (! return' {_0}) ] 
    [ & _0 : uint32 = any_l () : uint32
    | & y : uint32 = y
    | & x : uint32 = x
    | & _5 : uint32 = any_l () : uint32
    | & _6 : bool = any_l () : bool ]
    
end
