  type t_range  =
    | C_Range isize isize
    
  function any_l (_ : 'b) : 'a
  let rec range (input:t_range) (ret  (field_0:isize) (field_1:isize))= any 
    [ good (field_0:isize) (field_1:isize)-> {C_Range field_0 field_1 = input}
      ret {field_0} {field_1}
    | bad (field_0:isize) (field_1:isize)-> {C_Range field_0 field_1 <> input}
      {false}
      any ]
    
  function range_start (self : t_range) : isize =
    match self with
      | C_Range a _ -> a
      end
  function range_end (self : t_range) : isize =
    match self with
      | C_Range _ a -> a
      end
end
