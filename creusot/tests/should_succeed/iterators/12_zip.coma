
module C12Zip_Zip_Type
  type t_zip 'a 'b =
    | C_Zip 'a 'b
    
  function any_l (_ : 'b) : 'a
  let rec zip < 'a > < 'b > (input:t_zip 'a 'b) (ret  (field_0:'a) (field_1:'b))= any 
    [ good (field_0:'a) (field_1:'b)-> {C_Zip field_0 field_1 = input}
      ret {field_0} {field_1}
    | bad (field_0:'a) (field_1:'b)-> {C_Zip field_0 field_1 <> input}
      {false}
      any ]
    
  function zip_a (self : t_zip 'a 'b) : 'a =
    match self with
      | C_Zip a _ -> a
      end
  function zip_b (self : t_zip 'a 'b) : 'b =
    match self with
      | C_Zip _ a -> a
      end
end
