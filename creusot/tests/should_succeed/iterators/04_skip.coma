
module C04Skip_Skip_Type
  use prelude.UIntSize
  use prelude.Int
  type t_skip 'i =
    | C_Skip 'i usize
    
  function any_l (_ : 'b) : 'a
  let rec skip < 'i > (input:t_skip 'i) (ret  (field_0:'i) (field_1:usize))= any 
    [ good (field_0:'i) (field_1:usize)-> {C_Skip field_0 field_1 = input}
      ret {field_0} {field_1}
    | bad (field_0:'i) (field_1:usize)-> {C_Skip field_0 field_1 <> input}
      {false}
      any ]
    
  function skip_n (self : t_skip 'i) : usize =
    match self with
      | C_Skip _ a -> a
      end
  function skip_iter (self : t_skip 'i) : 'i =
    match self with
      | C_Skip a _ -> a
      end
end
