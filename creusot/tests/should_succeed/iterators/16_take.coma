
module C16Take_Take_Type
  use prelude.UIntSize
  use prelude.Int
  type t_take 'i =
    | C_Take 'i usize
    
  function any_l (_ : 'b) : 'a
  let rec take < 'i > (input:t_take 'i) (ret  (field_0:'i) (field_1:usize))= any 
    [ good (field_0:'i) (field_1:usize)-> {C_Take field_0 field_1 = input}
      ret {field_0} {field_1}
    | bad (field_0:'i) (field_1:usize)-> {C_Take field_0 field_1 <> input}
      {false}
      any ]
    
  function take_n (self : t_take 'i) : usize =
    match self with
      | C_Take _ a -> a
      end
  function take_iter (self : t_take 'i) : 'i =
    match self with
      | C_Take a _ -> a
      end
end
