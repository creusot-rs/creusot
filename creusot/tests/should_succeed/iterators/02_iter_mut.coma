    | C_IterMut (borrowed (slice 't))
    
  function any_l (_ : 'b) : 'a
  let rec iter_mut < 't > (input:t_itermut 't) (ret  (field_0:borrowed (slice 't)))= any 
    [ good (field_0:borrowed (slice 't))-> {C_IterMut field_0 = input}
      ret {field_0}
    | bad (field_0:borrowed (slice 't))-> {C_IterMut field_0 <> input}
      {false}
      any ]
    
  function itermut_inner (self : t_itermut 't) : borrowed (slice 't) =
    match self with
      | C_IterMut a -> a
      end
end
