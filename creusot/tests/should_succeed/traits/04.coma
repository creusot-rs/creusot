  let rec user (a:t) (b:t) (return'  (ret:bool))= {[#"../04.rs" 12 25 12 26] inv0 b}
    {[#"../04.rs" 12 18 12 19] inv0 a}
    (! bb0 
    [ bb0 = func10 {a} {b} (fun (_ret':bool) -> [ &_4 <- _ret' ] bb1)
    | bb1 = any [ br0 -> {_4 = false} (! bb6) | br1 -> {_4} (! bb2) ] 
