
module C02_Omg
  type t
  predicate invariant1 (self : t)
  let rec invariant1 (self:t) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = invariant1 self} (! return' {result}) ]
    
  predicate inv1 (_x : t)
  let rec inv1 (_x:t) (return'  (ret:bool))= any [ return' (result:bool)-> {result = inv1 _x} (! return' {result}) ] 
  axiom inv1 : forall x : t . inv1 x = true
  predicate invariant0 (self : t)
  let rec invariant0 (self:t) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = invariant0 self} (! return' {result}) ]
    
  predicate inv0 (_x : t)
  let rec inv0 (_x:t) (return'  (ret:bool))= any [ return' (result:bool)-> {result = inv0 _x} (! return' {result}) ] 
  axiom inv0 : forall x : t . inv0 x = true
  use prelude.Intrinsic
  use prelude.Borrow
  let rec is_true0 (self:t) (return'  (ret:bool))= {[#"../02.rs" 7 16 7 20] inv1 self}
    any [ return' (result:bool)-> {[#"../02.rs" 6 14 6 28] result = true} (! return' {result}) ] 
  predicate resolve0 (self : t)
  let rec resolve0 (self:t) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = resolve0 self} (! return' {result}) ]
    
  let rec omg (a:t) (return'  (ret:bool))= {[#"../02.rs" 11 17 11 18] inv0 a}
    (! bb0 
    [ bb2 = return' {_0} 
    | bb1 = {[@expl:type invariant] inv0 a}
      -{resolve0 a}- bb2 
    | bb0 = is_true0 {a} (fun (_ret':bool) -> [ &_0 <- _ret' ] bb1)  ]
    ) [ return' (result:bool)-> {[#"../02.rs" 10 10 10 24] result = true} (! return' {_0}) ] 
    [ & _0 : bool = any_l () : bool | & a : t = a ]
    
end
