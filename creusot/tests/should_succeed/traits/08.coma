
module C08_Tr_Program
  type self
  predicate invariant0 (self : self)
  let rec invariant0 (self:self) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = invariant0 self} (! return' {result}) ]
    
  predicate inv0 (_x : self)
  let rec inv0 (_x:self) (return'  (ret:bool))= any [ return' (result:bool)-> {result = inv0 _x} (! return' {result}) ] 
  axiom inv0 : forall x : self . inv0 x = true
  use prelude.Borrow
  use prelude.Intrinsic
  predicate resolve0 (self : self)
  let rec resolve0 (self:self) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = resolve0 self} (! return' {result}) ]
    
  let rec program (self:self) (return'  (ret:()))= {[#"../08.rs" 12 16 12 20] inv0 self}
    (! bb0 
    [ bb0 = [ &_0 <- [#"../08.rs" 12 22 12 24] () ] {[@expl:type invariant] inv0 self} -{resolve0 self}- return' {_0}  ]
    ) [ return' (result:())-> (! return' {_0}) ] [ & _0 : () = any_l () : () | & self : self = self ] 
end
module C08_Test
  type t
  predicate invariant0 (self : t)
  let rec invariant0 (self:t) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = invariant0 self} (! return' {result}) ]
    
  predicate inv0 (_x : t)
  let rec inv0 (_x:t) (return'  (ret:bool))= any [ return' (result:bool)-> {result = inv0 _x} (! return' {result}) ] 
  axiom inv0 : forall x : t . inv0 x = true
  use prelude.Intrinsic
  predicate resolve0 (self : t)
  let rec resolve0 (self:t) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = resolve0 self} (! return' {result}) ]
    
  let rec test (_1:t) (return'  (ret:()))= {inv0 _1}
    (! bb0 
    [ bb1 = return' {_0} 
    | bb0 = [ &_0 <- [#"../08.rs" 15 25 15 27] () ] {[@expl:type invariant] inv0 _1}
      -{resolve0 _1}- bb1  ]
    ) [ return' (result:())-> (! return' {_0}) ] [ & _0 : () = any_l () : () | & _1 : t = _1 ] 
end
