
module C06_Test
  type t
  type tgt0
  predicate invariant1 (self : tgt0)
  let rec invariant1 (self:tgt0) (return'  (ret:bool))= any 
    [ return' (result:bool)-> {result = invariant1 self} (! return' {result}) ]
    
  predicate inv1 (_x : tgt0)
  let rec inv1 (_x:tgt0) (return'  (ret:bool))= any [ return' (result:bool)-> {result = inv1 _x} (! return' {result}) ] 
