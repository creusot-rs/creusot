  let rec ix0 (self:t) (ix:usize) (return'  (ret:tgt0))= {[#"../06.rs" 6 11 6 15] inv0 self}
    any [ return' (result:tgt0)-> {[#"../06.rs" 6 31 6 40] inv1 result} (! return' {result}) ] 
  let rec test (a:t) (return'  (ret:tgt0))= {[#"../06.rs" 9 19 9 20] inv0 a}
    (! bb0 
    [ bb1 = return' {_0} 
    | bb0 = {[@expl:type invariant] inv0 a}
      -{resolve0 a}- ix0 {a} {[#"../06.rs" 13 9 13 10] (0 : usize)} (fun (_ret':tgt0) -> [ &_0 <- _ret' ] bb1)  ]
    ) [ return' (result:tgt0)-> {[#"../06.rs" 9 29 9 35] inv1 result} (! return' {_0}) ] 
    [ & _0 : tgt0 = any_l () : tgt0 | & a : t = a ]
    
end
