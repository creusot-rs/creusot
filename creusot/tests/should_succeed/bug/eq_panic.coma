  function deep_model1 (self : t) : deep_model_ty0 =
    [#"../../../../../creusot-contracts/src/model.rs" 74 8 74 28] deep_model2 self
  let rec deep_model1 (self:t) (return'  (ret:deep_model_ty0))= any 
