
module C768_A_Type
  use prelude.UIntSize
  use prelude.Int
  type t_a  =
    | C_A usize usize
    
  function any_l (_ : 'b) : 'a
  let rec a (input:t_a) (ret  (field_0:usize) (field_1:usize))= any 
    [ good (field_0:usize) (field_1:usize)-> {C_A field_0 field_1 = input}
      ret {field_0} {field_1}
    | bad (field_0:usize) (field_1:usize)-> {C_A field_0 field_1 <> input}
      {false}
      any ]
    
  function a_r (self : t_a) : usize =
    match self with
      | C_A _ a -> a
      end
end
