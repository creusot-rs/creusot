
module C256_U8Safe
  use prelude.Intrinsic
  use prelude.Int
  use prelude.UInt8
  let rec u8_safe (u:uint8) (return'  (ret:()))= (! bb0 
    [ bb0 = UInt8.add {u} {[#"../256.rs" 4 16 4 17] (0 : uint8)} (fun (_ret':uint8) -> [ &_2 <- _ret' ] 
        [ &_0 <- [#"../256.rs" 3 22 5 1] () ]
        return' {_0})  ]
    ) [ return' (result:())-> (! return' {_0}) ] 
    [ & _0 : () = any_l () : () | & u : uint8 = u | & _2 : uint8 = any_l () : uint8 ]
    
end
