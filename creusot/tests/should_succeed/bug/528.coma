
module C528_Neq
  use prelude.Intrinsic
  use prelude.Bool
  let rec neq (a:bool) (b:bool) (return'  (ret:bool))= (! bb0 [ bb0 = [ &_0 <- Bool.ne a b ] return' {_0} ] )
    [ & _0 : bool = any_l () : bool | & a : bool = a | & b : bool = b ]
     [ return' (result:bool)-> (! return' {result}) ] 
end
