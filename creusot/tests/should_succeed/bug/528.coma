
module C528_Neq
  use prelude.Intrinsic
  use prelude.Bool
  let rec neq (a:bool) (b:bool) (return'  (ret:bool))= (! bb0 
    [ bb0 = Bool.ne {a} {b} (fun (_ret':bool) -> [ &_0 <- _ret' ] return' {_0})  ]
    ) [ return' (result:bool)-> (! return' {_0}) ] [ & _0 : bool = any_l () : bool | & a : bool = a | & b : bool = b ] 
end
