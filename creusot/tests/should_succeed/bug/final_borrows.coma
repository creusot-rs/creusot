          -{resolve0 _2}- {[@expl:type invariant] inv0 r}
          -{resolve0 r}- return' {_0})) ]
    )[ & _0 : borrowed t = any_l () : borrowed t | & r : borrowed t = r | & _2 : borrowed t = any_l () : borrowed t ]  
    [ return' (result:borrowed t)-> {[#"../final_borrows.rs" 5 36 5 42] inv0 result}
