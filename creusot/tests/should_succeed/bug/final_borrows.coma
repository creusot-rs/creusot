    [#"../../../../../creusot-contracts/src/resolve.rs" 16 8 16 60] resolve2 (let (a, _) = self in a) /\ resolve3 (let (_, a) = self in a)
  let rec resolve1 (self:(borrowed (t, t), t)) (return'  (ret:bool))= any 
