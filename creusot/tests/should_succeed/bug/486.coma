
module C486_HasMutRef_Type
  use prelude.Borrow
  type t_hasmutref 't =
    | C_HasMutRef (borrowed 't)
    
  function any_l (_ : 'b) : 'a
  let rec has_mut_ref < 't > (input:t_hasmutref 't) (ret  (field_0:borrowed 't))= any 
    [ good (field_0:borrowed 't)-> {C_HasMutRef field_0 = input}
      ret {field_0}
    | bad (field_0:borrowed 't)-> {C_HasMutRef field_0 <> input}
      {false}
      any ]
    
  function hasmutref_0 (self : t_hasmutref 't) : borrowed 't =
    match self with
      | C_HasMutRef a -> a
      end
end
