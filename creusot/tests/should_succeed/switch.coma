
module Switch_Option_Type
  type t_option 't =
    | C_Some 't
    | C_None
    
  function any_l (_ : 'b) : 'a
  function some_0 (self : t_option 't) : 't =
    match self with
      | C_Some a -> a
      | C_None -> any_l self
      end
end
